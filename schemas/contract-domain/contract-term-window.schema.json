{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/contractforge/contract-domain/contract-term-window.schema.json",
  "title": "Contract Term Window",
  "type": "object",
  "required": ["term_window_id", "document_id"],
  "properties": {
    "term_window_id": { "type": "string" },
    "document_id": { "type": "string" },
    "clause_id": { "type": "string" },
    "window_type": { "type": "string" },
    "effective_start": { "type": "string", "format": "date-time" },
    "effective_end": { "type": "string", "format": "date-time" },
    "notice_period": { "type": "string" },
    "cure_period": { "type": "string" },
    "renewal_rule": { "type": "string" },
    "retroactivity_rule": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_path"],
        "properties": {
          "source_path": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}