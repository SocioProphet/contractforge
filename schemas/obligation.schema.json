{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.io/schemas/contractforge/obligation.schema.json",
  "title": "ContractForgeObligation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "obligationId",
    "obligationType",
    "source",
    "subjectRef",
    "action",
    "effect",
    "effectiveTime",
    "policyMapping",
    "evidenceRefs"
  ],
  "properties": {
    "schemaVersion": { "const": "v0.1" },
    "obligationId": { "type": "string", "minLength": 1 },
    "obligationType": {
      "type": "string",
      "enum": ["confidentiality", "ai_use_restriction", "approval_requirement", "billing_rule", "information_barrier", "retention", "disclosure", "economic_adjustment"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": { "type": "string", "enum": ["contract", "guideline", "policy", "schedule", "amendment", "other"] },
        "ref": { "type": "string", "minLength": 1 },
        "section": { "type": "string" },
        "hash": { "type": "string" }
      }
    },
    "subjectRef": { "type": "string", "minLength": 1 },
    "beneficiaryRef": { "type": "string" },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verb", "resourceClass"],
      "properties": {
        "verb": { "type": "string", "minLength": 1 },
        "resourceClass": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "effect": { "type": "string", "enum": ["allow", "deny", "require_approval", "escalate", "record", "notify"] },
    "effectiveTime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startsAt"],
      "properties": {
        "startsAt": { "type": "string", "minLength": 1 },
        "endsAt": { "type": "string" },
        "amends": { "type": "string" }
      }
    },
    "policyMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyFamily", "policyId", "policyVersion"],
      "properties": {
        "policyFamily": { "type": "string", "minLength": 1 },
        "policyId": { "type": "string", "minLength": 1 },
        "policyVersion": { "type": "string", "minLength": 1 }
      }
    },
    "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
