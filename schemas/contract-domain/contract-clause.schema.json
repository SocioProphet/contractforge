{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/contractforge/contract-domain/contract-clause.schema.json",
  "title": "Contract Clause",
  "type": "object",
  "required": [
    "clause_id",
    "document_id",
    "clause_type",
    "text",
    "span"
  ],
  "properties": {
    "clause_id": {
      "type": "string"
    },
    "document_id": {
      "type": "string"
    },
    "section_path": {
      "type": "array",
      "items": { "type": "string" }
    },
    "clause_type": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "span": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "integer", "minimum": 0 },
        "end": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "cross_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_path"],
        "properties": {
          "source_path": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}