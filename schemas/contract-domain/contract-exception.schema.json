{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/contractforge/contract-domain/contract-exception.schema.json",
  "title": "Contract Exception",
  "type": "object",
  "required": ["exception_id", "document_id", "clause_id"],
  "properties": {
    "exception_id": { "type": "string" },
    "document_id": { "type": "string" },
    "clause_id": { "type": "string" },
    "scope": { "type": "string" },
    "overrides_artifact_ref": { "type": "string" },
    "condition": { "type": "string" },
    "text": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rule_hits": { "type": "array", "items": { "type": "string" } },
    "model_scores": { "type": "object", "additionalProperties": { "type": "number" } },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_path"],
        "properties": {
          "source_path": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}