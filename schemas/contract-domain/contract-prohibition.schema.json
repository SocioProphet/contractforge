{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/contractforge/contract-domain/contract-prohibition.schema.json",
  "title": "Contract Prohibition",
  "type": "object",
  "required": ["prohibition_id", "document_id", "clause_id", "action"],
  "properties": {
    "prohibition_id": { "type": "string" },
    "document_id": { "type": "string" },
    "clause_id": { "type": "string" },
    "subject": { "type": "string" },
    "counterparty": { "type": "string" },
    "action": { "type": "string" },
    "object": { "type": "string" },
    "condition": { "type": "string" },
    "exception": { "type": "string" },
    "trigger": { "type": "string" },
    "timeframe": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rule_hits": { "type": "array", "items": { "type": "string" } },
    "model_scores": { "type": "object", "additionalProperties": { "type": "number" } },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_path"],
        "properties": {
          "source_path": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}